# Example environment configuration for the AssetMind AI API.
# Copy to apps/api/.env and adjust. NEVER commit a real .env or any secret.

# ── App metadata (optional) ──────────────────────────────────────────────────
PROJECT_NAME=AssetMind AI API
SERVICE_NAME=assetmind-ai-api
ENVIRONMENT=development

# ── Persistence ──────────────────────────────────────────────────────────────
# "postgres" enables the full RAG / knowledge-graph pipeline (required for the
# demo, benchmark and all /agents routes). "json" is a local-only fallback.
PERSISTENCE_BACKEND=postgres

# Postgres + pgvector connection string. The value below matches the local
# docker-compose "db" service and uses PLACEHOLDER credentials only.
# In production point this at a hosted pgvector Postgres (Neon / Supabase).
DATABASE_URL=postgresql+psycopg://assetmind:assetmind@localhost:5432/assetmind

# Local directory for uploaded originals and generated evidence packages.
# NOTE: evidence packages under $STORAGE_DIR/exports are EPHEMERAL — on a
# container platform they do not survive a restart/redeploy (see docs/deployment.md).
STORAGE_DIR=storage

# ── CORS ─────────────────────────────────────────────────────────────────────
# Browser origins allowed to call the API. Pydantic parses this as JSON.
# Local dev default is the Next.js dev server; add your deployed frontend origin.
CORS_ORIGINS=["http://localhost:3000"]

# ── Gemini (optional) ────────────────────────────────────────────────────────
# Leave GEMINI_API_KEY empty to run in deterministic local mode: hashing
# embeddings (local-hashing-v1) + extractive answers, no external calls. Set a
# key to switch embeddings and answer generation to Gemini.
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_GENERATION_MODEL=gemini-2.5-flash

# Enables Gemini for agent reasoning (RCA). Unset => deterministic fallback.
LLM_PROVIDER=

# ── Evaluation ───────────────────────────────────────────────────────────────
# Optional override for the benchmark results file served by GET /evaluation/latest.
# Unset => in-repo data/benchmark/results_sample.json.
# BENCHMARK_RESULTS_PATH=/app/data/benchmark/results_sample.json
