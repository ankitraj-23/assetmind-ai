# Example environment configuration for the AssetMind AI API.
# Copy to apps/api/.env and adjust as needed. Do not commit your real .env.

# Persistence backend selector: "json" (default, local filesystem) or "postgres".
PERSISTENCE_BACKEND=json

# Postgres connection string (used only when PERSISTENCE_BACKEND=postgres).
# Matches the local docker-compose "db" service. Placeholder credentials only.
DATABASE_URL=postgresql+psycopg://assetmind:assetmind@localhost:5432/assetmind
