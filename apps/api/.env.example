# Example environment configuration for the AssetMind AI API.
# Copy to apps/api/.env and adjust as needed. Do not commit your real .env.

# Optional app metadata.
PROJECT_NAME=AssetMind AI API
SERVICE_NAME=assetmind-ai-api
ENVIRONMENT=development

# Local directory for the existing JSON/filesystem upload pipeline.
STORAGE_DIR=storage

# Browser origins allowed by CORS. Pydantic reads list env vars as JSON.
CORS_ORIGINS=["http://localhost:3000"]

# Persistence backend selector: "json" (default, local filesystem) or "postgres".
# Use "postgres" for the Week 1 /rag pipeline.
PERSISTENCE_BACKEND=json

# Postgres connection string (used only when PERSISTENCE_BACKEND=postgres).
# Matches the local docker-compose "db" service. Placeholder credentials only.
DATABASE_URL=postgresql+psycopg://assetmind:assetmind@localhost:5432/assetmind

# Gemini is required only for the Week 1 /rag ingestion and query pipeline.
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_GENERATION_MODEL=gemini-3.5-flash
